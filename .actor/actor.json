{
  "actorSpecification": 1,
  "name": "meesho-social-commerce-scraper",
  "title": "Meesho Product Scraper: Prices & Catalog",
  "description": "Scrape public Meesho product search results for titles, prices, MRP, discounts, ratings, categories, sizes, stock flags, image URLs, and product URLs.",
  "version": "1.0",
  "buildTag": "latest",
  "dockerfile": "Dockerfile",
  "input": "../INPUT_SCHEMA.json",
  "readme": "../README.md",
  "exampleRunInput": {
    "body": "{\"searchQueries\":[\"kurti\"],\"includeAds\":false,\"maxResults\":1,\"maxPagesPerQuery\":1,\"proxyConfiguration\":{\"useApifyProxy\":true,\"apifyProxyGroups\":[\"RESIDENTIAL\"],\"apifyProxyCountry\":\"IN\"}}",
    "contentType": "application/json; charset=utf-8"
  },
  "output": "./output_schema.json",
  "categories": ["ECOMMERCE", "AUTOMATION"],
  "categoriesVersion": "1.0.0",
  "pricingInfo": {
    "pricingModel": "PAY_PER_EVENT",
    "pricingPerEvent": {
      "actorChargeEvents": {
        "apify-actor-start": {
          "eventTitle": "Actor Start",
          "eventDescription": "Charged when the Actor starts running. Number of events charged depends on Actor memory (one event per GB, minimum one event).",
          "eventPriceUsd": 0.00005,
          "isPrimaryEvent": false,
          "isOneTimeEvent": true
        },
        "product-scraped": {
          "eventTitle": "Product scraped",
          "eventDescription": "Charged once for each clean Meesho product saved to the dataset.",
          "eventPriceUsd": 0.002,
          "isPrimaryEvent": true,
          "isOneTimeEvent": false
        }
      }
    }
  },
  "storages": {
    "dataset": "./dataset_schema.json"
  },
  "defaultRunOptions": {
    "build": "latest",
    "memoryMbytes": 512,
    "timeoutSecs": 900
  },
  "minMemoryMbytes": 256,
  "maxMemoryMbytes": 2048
}
