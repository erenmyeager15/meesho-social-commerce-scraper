{
    "actorSpecification": 1,
    "name": "meesho-social-commerce-scraper",
    "title": "Meesho Product Scraper - Social Commerce Data",
    "description": "Collect public Meesho product catalog data including prices, ratings, reviews, categories, delivery flags, images, tags, sizes, and product URLs.",
    "version": "1.0",
    "pricingInfo": {
        "pricingModel": "PAY_PER_EVENT",
        "pricingPerEvent": {
            "actorChargeEvents": {
                "product-scraped": {
                    "eventTitle": "Product scraped",
                    "eventDescription": "Charged once for each clean Meesho product saved to the dataset.",
                    "eventPriceUsd": 0.002,
                    "isPrimaryEvent": true,
                    "isOneTimeEvent": false
                }
            }
        }
    },
    "categories": ["ECOMMERCE", "AUTOMATION", "OTHER"],
    "minMemoryMbytes": 512,
    "maxMemoryMbytes": 4096,
    "defaultRunOptions": {
        "build": "latest",
        "memoryMbytes": 1024,
        "timeoutSecs": 43200
    },
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "views": {
                "products": {
                    "title": "Products",
                    "transformation": {
                        "fields": [
                            "imageUrl",
                            "searchQuery",
                            "position",
                            "catalogId",
                            "productId",
                            "productName",
                            "category",
                            "price",
                            "rating",
                            "ratingCount",
                            "reviewCount",
                            "freeDelivery",
                            "shippingCharges",
                            "mallVerified",
                            "isAdProduct",
                            "productUrl",
                            "scrapedAt"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "imageUrl": {
                                "label": "Image",
                                "format": "image"
                            },
                            "searchQuery": {
                                "label": "Search",
                                "format": "text"
                            },
                            "position": {
                                "label": "Position",
                                "format": "number"
                            },
                            "catalogId": {
                                "label": "Catalog ID",
                                "format": "text"
                            },
                            "productId": {
                                "label": "Product ID",
                                "format": "text"
                            },
                            "productName": {
                                "label": "Product",
                                "format": "text"
                            },
                            "category": {
                                "label": "Category",
                                "format": "text"
                            },
                            "price": {
                                "label": "Price",
                                "format": "number"
                            },
                            "rating": {
                                "label": "Rating",
                                "format": "number"
                            },
                            "ratingCount": {
                                "label": "Ratings",
                                "format": "number"
                            },
                            "reviewCount": {
                                "label": "Reviews",
                                "format": "number"
                            },
                            "freeDelivery": {
                                "label": "Free Delivery",
                                "format": "boolean"
                            },
                            "shippingCharges": {
                                "label": "Shipping",
                                "format": "number"
                            },
                            "mallVerified": {
                                "label": "Mall Verified",
                                "format": "boolean"
                            },
                            "isAdProduct": {
                                "label": "Ad",
                                "format": "boolean"
                            },
                            "productUrl": {
                                "label": "URL",
                                "format": "link"
                            },
                            "scrapedAt": {
                                "label": "Scraped At",
                                "format": "date"
                            }
                        }
                    }
                }
            }
        }
    },
    "input": "../INPUT_SCHEMA.json",
    "dockerfile": "Dockerfile",
    "webScraper": false
}
